{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": false,
    "topFilesLen": 10,
    "showLineNumbers": true,
    "copyToClipboard": false
  },
  "include": [
    "index.html",
    "assets/css/**",
    "assets/js/**",
    "scripts/**",
    "package.json",
    ".gitignore",
    "repomix.config.json",
    "README.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "assets/images/**",
      "ingest/**",
      "node_modules/**",
      "repomix-output*",
      "*.psd",
      "*.psb",
      "*.pdf",
      "*.ai"
    ]
  }
}
